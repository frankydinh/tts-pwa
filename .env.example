# Upstash Redis (Serverless Database)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cloud TTS API
# Google Cloud Text-to-Speech API key
TTS_API_KEY=your-google-tts-api-key
# Optional: override default TTS endpoint
TTS_API_ENDPOINT=https://texttospeech.googleapis.com/v1/text:synthesize

# Audio Storage Path (local dev only; use cloud storage in production)
AUDIO_STORAGE_PATH=/tmp/audio

# Server Port (local dev)
PORT=3000
