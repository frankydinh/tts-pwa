{
  "name": "tech-audiobook-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "A Progressive Web App to convert technical PDF documents into high-quality audio using Cloud TTS APIs.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm-run-all build:shared build:api build:web",
    "build:shared": "npm run build -w packages/shared-types",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "overrides": {
    "multer": "^2.1.1",
    "@nestjs/platform-express": {
      "multer": "^2.1.1"
    }
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
